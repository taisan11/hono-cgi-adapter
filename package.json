{
  "name": "hono-cgi-adapter",
  "version": "0.0.3",
  "description": "CGI/FastCGI adapter for Hono",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run build"
  },
  "license": "MIT",
  "author": "taisan11",
  "repository": {
    "type": "git",
    "url": "https://github.com/taisan11/hono-cgi-adapter.git"
  },
  "keywords": [
    "hono",
    "cgi",
    "fastcgi",
    "adapter"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "mitata": "^1.0.34"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "hono": "^4.12.18"
  }
}
